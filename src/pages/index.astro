---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import Pricing from '../components/Pricing.astro';
import Faq from '../components/Faq.astro';

const pageTitle = "Développeur Web Freelance à Carros & Nice | Création Site Internet | William SART";
const pageDescription = "Développeur web basé à Carros (06). Je crée des sites vitrines ultra-rapides et des applications sur-mesure pour les artisans et TPE des Alpes-Maritimes.";
---

<Layout title={pageTitle} description={pageDescription}>
    <main>
        <Hero />
        <Services />
        <Portfolio />
        <Pricing />
        <Faq />
    </main>
</Layout>