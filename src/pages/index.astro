---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import Pricing from '../components/Pricing.astro';
import Faq from '../components/Faq.astro';

const pageTitle = "Création Site Internet pour Artisans & TPE à Carros | William SART";
const pageDescription = "Besoin d'un site web à Carros ou dans la Plaine du Var ? Expert en création de sites vitrines et SEO pour les artisans et TPE des Alpes-Maritimes (06). Diagnostic gratuit.";
---

<Layout title={pageTitle} description={pageDescription}>
    <main>
        <Hero />
        <Services />
        <Portfolio />
        <Pricing />
        <Faq />
    </main>
</Layout>