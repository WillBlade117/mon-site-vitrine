<section class="relative bg-artisan-bg overflow-hidden">
    <div class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 blur-3xl opacity-30 pointer-events-none">
        <div class="aspect-square h-[600px] rounded-full bg-artisan-accent/20"></div>
    </div>

    <div class="relative mx-auto max-w-5xl px-6 py-24 md:py-26 lg:py-28">
        <div class="flex flex-col items-center text-center">
            
            <span class="mb-6 inline-block rounded-full bg-artisan-accent/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-wider text-artisan-accent">
                Développeur Web à Carros — Spécialiste TPE & Artisans
            </span>
            
            <h1 class="font-serif text-4xl font-black tracking-tight text-artisan-text md:text-6xl lg:text-7xl max-w-4xl leading-[1.1]">
                Faites de votre site votre meilleur commercial à <span class="text-artisan-accent">Carros.</span>
            </h1>
            
            <p class="mt-8 max-w-2xl text-lg md:text-xl text-artisan-muted font-sans leading-relaxed">
                Je ne crée pas juste des sites : je bâtis votre visibilité locale. J'optimise votre présence sur 
                Google et Google Maps pour que les clients de Carros vous trouvent en premier. Zéro 
                technique pour vous, 100% de résultats pour votre activité.
            </p>
            
            <div class="mt-10 flex flex-col w-full sm:w-auto sm:flex-row items-center justify-center gap-4 font-sans font-semibold">
                
                <a href="#contact" class="w-full sm:w-auto rounded-lg bg-artisan-accent px-8 py-4 text-white shadow-sm hover:bg-artisan-accent-hover transition-all duration-200 transform hover:-translate-y-1 flex items-center justify-center gap-2">
                    Discuter de mon projet (Gratuit)
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                        <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                      </svg>
                </a>
                
                <a href="#portfolio" class="w-full sm:w-auto rounded-lg px-8 py-4 text-artisan-text ring-1 ring-inset ring-artisan-text/20 hover:bg-artisan-text/5 transition-all duration-200 flex items-center justify-center">
                    Voir mes réalisations
                </a>
            </div>

            <p class="mt-8 text-sm text-artisan-muted flex items-center gap-2 bg-white/50 px-4 py-2 rounded-full backdrop-blur-sm">
                <span class="flex h-2 w-2 relative">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                </span>
                Dispo actuellement pour 1 nouveau projet en<span id="current-month">...</span>
            </p>

            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const date = new Date();
                    date.setMonth(date.getMonth() + 1);
                    
                    const nextMonth = date.toLocaleString('fr-FR', { month: 'long' });
                    const monthElement = document.getElementById('current-month');
                    
                    if (monthElement) {
                        monthElement.textContent = nextMonth.charAt(0).toUpperCase() + nextMonth.slice(1);
                    }
                });
            </script>
        </div>
    </div>
</section>