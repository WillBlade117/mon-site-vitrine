---
import { Image } from "astro:assets";
// On remplace l'ancienne image par la nouvelle
import imgPressingBrignoles from "../assets/imgPressingBrignoles.jpg";
import imgSiteLAtelierArchi from "../assets/imgSiteLAtelierArchi.jpg";
---

<section id="portfolio" class="bg-artisan-bg py-24 md:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-20 max-w-2xl">
      <h2 class="font-serif text-3xl font-bold text-artisan-text md:text-5xl">
        Réalisations & Savoir-faire
      </h2>
      <p
        class="mt-6 text-lg text-artisan-muted font-sans border-l-4 border-artisan-accent pl-4"
      >
        Découvrez une sélection de projets clients et de démonstrateurs techniques. 
        L'objectif est toujours le même : allier un design qui inspire confiance à des 
        performances techniques redoutables pour développer votre activité.
      </p>
    </div>

    <div class="space-y-24 md:space-y-32">
      
      <div
        class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 items-center"
      >
        <div
          class="relative group rounded-2xl overflow-hidden shadow-xl ring-1 ring-artisan-text/5 bg-gray-100 aspect-[4/3]"
        >
          <Image
            src={imgPressingBrignoles}
            alt="Site internet Pressing Saint Jean à Brignoles"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            width={800}
            format="webp"
          />
          <div
            class="absolute top-4 left-4 bg-artisan-accent text-white backdrop-blur-sm px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest shadow-sm"
          >
            Projet Client
          </div>
        </div>

        <div class="flex flex-col justify-center">
          <h3 class="font-serif text-3xl font-bold text-artisan-text mb-4">
            Pressing Saint Jean
          </h3>
          <p class="text-artisan-accent font-medium font-sans mb-2">
            Acquisition de clientèle & SEO Local
          </p>
          <p class="text-artisan-muted text-lg leading-relaxed mb-6 font-sans">
            Suite au rachat de l'entreprise, l'objectif du gérant était clair : se démarquer de son concurrent de quartier et capter un maximum de nouveaux clients à Brignoles. J'ai conçu un site moderne, "mobile-first" et extrêmement rapide, pensé pour dominer les résultats de recherche locale sur Google.
          </p>

          <div
            class="grid grid-cols-2 gap-6 mb-8 border-y border-artisan-text/10 py-6"
          >
            <div>
              <span
                class="block text-3xl font-serif font-bold text-artisan-accent"
                >100/100</span
              >
              <span class="text-sm text-artisan-muted">Score Performance</span>
            </div>
            <div>
              <span
                class="block text-3xl font-serif font-bold text-artisan-accent"
                >Mobile</span
              >
              <span class="text-sm text-artisan-muted">Design prioritaire</span>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-8">
            <span
              class="px-3 py-1 bg-artisan-text/5 text-artisan-text text-sm rounded-md font-medium"
              >SEO Local</span
            >
            <span
              class="px-3 py-1 bg-artisan-text/5 text-artisan-text text-sm rounded-md font-medium"
              >Astro</span
            >
            <span
              class="px-3 py-1 bg-artisan-text/5 text-artisan-text text-sm rounded-md font-medium"
              >Tailwind</span
            >
          </div>

          <a
            href="https://pressingsaintjean.fr/"
            target="_blank"
            class="inline-flex items-center gap-2 text-artisan-accent font-semibold hover:text-artisan-accent-hover transition-colors"
          >
            Voir le site
            <span class="text-xl">→</span>
          </a>
        </div>
      </div>

      <div
        class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16 items-center"
      >
        <div
          class="relative group rounded-2xl overflow-hidden shadow-xl ring-1 ring-artisan-text/5 bg-gray-100 aspect-[4/3] lg:order-last"
        >
          <Image
            src={imgSiteLAtelierArchi}
            alt="Démonstrateur site L'atelier Archi"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            width={800}
            format="webp"
          />
          <div
            class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest text-artisan-text shadow-sm"
          >
            Preuve de Concept (POC)
          </div>
        </div>

        <div class="flex flex-col justify-center">
          <h3 class="font-serif text-3xl font-bold text-artisan-text mb-4">
            L'Atelier Archi
          </h3>
          <p class="text-artisan-muted text-lg leading-relaxed mb-6 font-sans">
            Maquette fonctionnelle d'une plateforme pour un cabinet d'architecture. L'objectif de cette démonstration est de montrer comment allier un design immersif (pour valoriser les photos) à un système de gestion de contenu simple et autonome.
          </p>

          <div
            class="grid grid-cols-2 gap-6 mb-8 border-y border-artisan-text/10 py-6"
          >
            <div>
              <span
                class="block text-3xl font-serif font-bold text-artisan-accent"
                >100%</span
              >
              <span class="text-sm text-artisan-muted">Autonome</span>
            </div>
            <div>
              <span
                class="block text-3xl font-serif font-bold text-artisan-accent"
                >Design</span
              >
              <span class="text-sm text-artisan-muted">Sur-mesure</span>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-8">
            <span
              class="px-3 py-1 bg-artisan-text/5 text-artisan-text text-sm rounded-md font-medium"
              >Astro</span
            >
            <span
              class="px-3 py-1 bg-artisan-text/5 text-artisan-text text-sm rounded-md font-medium"
              >Tailwind</span
            >
            <span
              class="px-3 py-1 bg-artisan-text/5 text-artisan-text text-sm rounded-md font-medium"
              >Keystatic</span
            >
          </div>

          <a
            href="https://www.l-atelier-archi.william-sart.fr"
            target="_blank"
            class="inline-flex items-center gap-2 text-artisan-accent font-semibold hover:text-artisan-accent-hover transition-colors"
          >
            Explorer la démo
            <span class="text-xl">→</span>
          </a>
        </div>
      </div>
      
    </div>
  </div>
</section>